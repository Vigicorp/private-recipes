                "config/routes/vigicorp_datatable.yaml": {
                    "contents": [
                        "vigicorp_datatable:",
                        "      resource: '@VigicorpDatatableBundle/src/Controller/'",
                        "      type: attribute",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "07zhr159lvd6923v2w2odam3u83r8cv38jv0j1g2"
        }
    }
